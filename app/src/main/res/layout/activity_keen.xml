<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/keen_bg"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Browsing shell: chrome above page; pointer layer covers both for URL-bar hits. -->
    <FrameLayout
        android:id="@+id/browseShell"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/browseColumn"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/chromeBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FF000000"
                android:orientation="vertical"
                android:paddingTop="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/chromeLogo"
                        android:layout_width="28dp"
                        android:layout_height="26dp"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="3dp"
                        android:alpha="0.9"
                        android:background="@drawable/focusable_icon"
                        android:clickable="true"
                        android:contentDescription="@string/app_name"
                        android:focusable="true"
                        android:nextFocusRight="@id/browseUrlEdit"
                        android:padding="6dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/keen_mark" />

                    <!-- Editable address bar (pointer can focus this). -->
                    <EditText
                        android:id="@+id/browseUrlEdit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="#FF000000"
                        android:ellipsize="middle"
                        android:hint="@string/url_hint"
                        android:imeOptions="actionGo"
                        android:inputType="textUri"
                        android:nextFocusLeft="@id/chromeLogo"
                        android:nextFocusRight="@id/chromeFavButton"
                        android:paddingHorizontal="12dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="4dp"
                        android:singleLine="true"
                        android:textColor="#FFE8E8E8"
                        android:textColorHint="#FF666666"
                        android:textSize="14sp"
                        android:importantForAutofill="no" />

                    <!-- Favourite the current site (top-right of the address row). -->
                    <ImageView
                        android:id="@+id/chromeFavButton"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_marginEnd="12dp"
                        android:layout_marginTop="3dp"
                        android:alpha="0.35"
                        android:background="@drawable/focusable_icon"
                        android:clickable="true"
                        android:contentDescription="@string/fav_toggle"
                        android:focusable="true"
                        android:padding="7dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_star" />
                </LinearLayout>

                <!-- browseChrome kept for binding/progress layout; hidden (no mode callouts). -->
                <TextView
                    android:id="@+id/browseChrome"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:visibility="gone" />

                <FrameLayout
                    android:id="@+id/loadProgressTrack"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:background="#FF000000">

                    <View
                        android:id="@+id/loadProgressBar"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="#FFFFFFFF"
                        android:visibility="invisible" />
                </FrameLayout>
            </LinearLayout>

            <FrameLayout
                android:id="@+id/browserContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>
    </FrameLayout>

    <!-- Fullscreen custom view host (WebChromeClient). Pointer layer stays ABOVE this. -->
    <FrameLayout
        android:id="@+id/fullscreenContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:descendantFocusability="blocksDescendants"
        android:visibility="gone" />

    <!-- Native torrent playback: ExoPlayer reaches platform audio decoders
         (E-AC-3/DTS) that WebView video cannot. Sits above browse shell and
         pointer; below the torrent loading overlay. -->
    <FrameLayout
        android:id="@+id/torrentPlayerContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:elevation="20dp"
        android:keepScreenOn="true"
        android:visibility="gone">

        <androidx.media3.ui.PlayerView
            android:id="@+id/torrentPlayerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:focusable="true"
            app:resize_mode="fit"
            app:show_buffering="never"
            app:show_subtitle_button="true"
            app:surface_type="surface_view" />

        <!-- Hold-to-seek feedback: target time + delta while DPAD left/right is held. -->
        <TextView
            android:id="@+id/torrentSeekPreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="96dp"
            android:background="@drawable/seek_preview_bg"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            android:textColor="#FFF2F4F8"
            android:textSize="22sp"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Torrent startup feedback: covers the page from click to first playable pieces. -->
    <FrameLayout
        android:id="@+id/torrentLoadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:clickable="true"
        android:focusable="false"
        android:elevation="24dp"
        android:visibility="gone">

        <!-- Jumbo watermark: the real number, huge and faded, behind everything else.
             JumboPercentView draws from actual glyph ink bounds so the digits run edge to
             edge — a TextView (even autoSize) centers on font-metrics line height, which
             reserves dead space for ascenders/descenders these digits never use and can
             never truly touch the edges. "invisible" (not "gone") from the start so it's
             already laid out with real width/height the instant the first buffering percent
             arrives. Faded so it reads as texture, not competing with what's drawn on top. -->
        <com.keenzero.app.home.JumboPercentView
            android:id="@+id/torrentLoadingPercentGiant"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:visibility="invisible" />

        <LinearLayout
            android:id="@+id/torrentLoadingContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <com.keenzero.app.home.SpinnerBarsView
                android:id="@+id/torrentLoadingSpinner"
                android:layout_width="220dp"
                android:layout_height="44dp" />

            <TextView
                android:id="@+id/torrentLoadingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/torrent_loading_title"
                android:textColor="@color/keen_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- Peer stat lock-up: three EQUAL-WIDTH columns (weighted), each a bold
                 number centred over a small tracked label. Equal widths keep the middle
                 column dead-centre under the title regardless of differing label widths.
                 Hidden until a real seeder/leecher breakdown arrives, then fades in. -->
            <LinearLayout
                android:id="@+id/torrentLoadingStats"
                android:layout_width="264dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/statSeeders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/keen_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:letterSpacing="0.14"
                        android:text="@string/torrent_stat_seeders"
                        android:textColor="@color/keen_muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/statLeechers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/keen_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:letterSpacing="0.14"
                        android:text="@string/torrent_stat_leechers"
                        android:textColor="@color/keen_muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/statSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/keen_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:letterSpacing="0.14"
                        android:text="@string/torrent_stat_speed"
                        android:textColor="@color/keen_muted"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Failed / stalled page state: branded, remote-friendly, with a focused Retry. -->
    <LinearLayout
        android:id="@+id/errorShell"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/keen_bg"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="48dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="60dp"
            android:layout_height="52dp"
            android:layout_marginBottom="28dp"
            android:alpha="0.45"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter"
            android:src="@drawable/keen_mark" />

        <TextView
            android:id="@+id/errorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="@string/error_title"
            android:textColor="@color/keen_text"
            android:textSize="26sp" />

        <TextView
            android:id="@+id/errorHost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/keen_text"
            android:textSize="16sp"
            android:alpha="0.85" />

        <TextView
            android:id="@+id/errorReason"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_horizontal"
            android:textColor="@color/keen_muted"
            android:textSize="14sp" />

        <FrameLayout
            android:id="@+id/errorRetry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:background="@drawable/focusable_button"
            android:clickable="true"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:paddingHorizontal="36dp"
            android:paddingVertical="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="@string/error_retry"
                android:textColor="@color/keen_text"
                android:textSize="16sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/errorHomeHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/error_back_home"
            android:textColor="@color/keen_hint"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Keen-owned pointer: always a root sibling above browse + HTML fullscreen. -->
    <FrameLayout
        android:id="@+id/pointerLayer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clickable="false"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:elevation="32dp" />

    <!-- Native home — first frame independent of WebView. Clean black canvas:
         first run shows the faded K + address entry (IME auto-opens; adjustResize
         keeps the centered group above the keyboard); after playback it becomes
         the Continue watching surface. -->
    <FrameLayout
        android:id="@+id/homeShell"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <!-- Address row, pinned top-left: tiny mark + left-aligned input on one
             line, well clear of the bottom IME. Always reachable on home. -->
        <LinearLayout
            android:id="@+id/homeTopBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginStart="32dp"
            android:layout_marginTop="20dp"
            android:layout_marginEnd="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/homeBarLogo"
                android:layout_width="14dp"
                android:layout_height="12dp"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter"
                android:src="@drawable/keen_mark" />

            <EditText
                android:id="@+id/homeUrlInput"
                android:layout_width="480dp"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:hint="@string/url_hint"
                android:imeOptions="actionGo"
                android:inputType="textUri"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingVertical="6dp"
                android:singleLine="true"
                android:textColor="@color/keen_text"
                android:textColorHint="#FF4A4F58"
                android:textSize="14sp"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- First-run / empty state: faded centered mark. adjustResize keeps it
             centered in the space left above the auto-opened keyboard. -->
        <FrameLayout
            android:id="@+id/homeCenterGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center">

            <ImageView
                android:id="@+id/homeLogo"
                android:layout_width="176dp"
                android:layout_height="145dp"
                android:alpha="0.4"
                android:contentDescription="@string/app_name"
                android:scaleType="fitCenter"
                android:src="@drawable/keen_mark" />
        </FrameLayout>

        <!-- Home content column: Favs roundels above the Continue watching card.
             clipChildren/clipToPadding=false throughout this column: focus-scale
             microinteractions grow tiles a few % past their laid-out box, and a
             LinearLayout's default clip would silently crop that growth away. -->
        <LinearLayout
            android:id="@+id/homeContentColumn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="24dp"
            android:layout_marginTop="48dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">

        <LinearLayout
            android:id="@+id/favsGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Roundels are added in code (one per favourite). -->
            <LinearLayout
                android:id="@+id/favsRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="horizontal" />
        </LinearLayout>

        <!-- Continue watching: left-aligned heading + Netflix-style card. -->
        <LinearLayout
            android:id="@+id/continueGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/continueHeading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="-0.015"
                android:text="@string/continue_watching"
                android:textColor="@color/keen_muted"
                android:textSize="26sp" />

            <!-- Up to 5 recently played titles, horizontally scrollable. Cards are
                 built in code (buildContinueCard) so the row stays data-driven. -->
            <HorizontalScrollView
                android:id="@+id/continueScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:scrollbars="none">

                <LinearLayout
                    android:id="@+id/continueRow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
        </LinearLayout>
        </LinearLayout>

        <!-- Hidden diagnostics surface (populated by evidence export intents). -->
        <TextView
            android:id="@+id/diagnosticsPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:padding="24dp"
            android:textColor="@color/keen_muted"
            android:textIsSelectable="true"
            android:textSize="12sp"
            android:visibility="gone" />
    </FrameLayout>
</FrameLayout>
