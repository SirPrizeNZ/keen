<?xml version="1.0" encoding="utf-8"?>
<!-- Fill only. The focus ring is an animated BorderDrawable foreground set in
     code, so it draws on top of the poster and isn't clipped by the card. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#FF23272F" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#FF161A22" />
        </shape>
    </item>
</selector>
